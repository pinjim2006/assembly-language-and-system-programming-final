 00000685  83 3D 0000035B R	    cmp dashAnimState, 1
	   01
 0000068C  75 05		    jne USE_STYLE
 0000068E  BE 0000036B R	    mov esi, OFFSET dashStyle2
 00000693			USE_STYLE:
				    ; 上邊框
