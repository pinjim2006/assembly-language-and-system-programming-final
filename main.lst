				; 繪製動態虛線游標 (根據 Dash Anim State 切換樣式)
 0000065D			drawMovingDashedCursor PROC USES eax esi edi
 00000660  FF 35 00000128 R	    push DWORD PTR outerBoxPos
 00000666  66| A1		    mov ax, blockPos.X
	   00000130 R
