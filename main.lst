				; =================================================================================
				; 視窗控制相關 API (Windows API)
				; =================================================================================
				INCLUDELIB user32.lib
				INCLUDELIB kernel32.lib
				
 = 00000003			SW_MAXIMIZE = 3
				GetConsoleWindow PROTO
				ShowWindow PROTO, hWnd:DWORD, nCmdShow:DWORD
				; SetConsoleScreenBufferSize 已經包含在 Irvine32 或標準庫中，但為了保險起見我們使用 Invoke 呼叫
				
				; =================================================================================
				; 函式原型宣告 (Function Prototypes)
				; =================================================================================
				initConsoleWindow PROTO     ; 初始化視窗大小並最大化
				outerBox PROTO              ; 繪製遊戲外框
				initBlock PROTO             ; 初始化游標位置
				drawMovingDashedCursor PROTO ; 繪製動態虛線游標
				hasMapComponentAtCursor PROTO ; 檢查游標位置是否有地圖元件
				toggleMenuState PROTO       ; 切換選單/遊戲模式
				handleNormalInput PROTO     ; 處理一般模式輸入
				handleSideMenuInput PROTO   ; 處理側邊選單輸入
				drawSideMenu PROTO          ; 繪製側邊選單
				drawSideMenuCursor PROTO    ; 繪製選單游標
				clearSideMenuCursor PROTO   ; 清除選單游標
				updateDashAnimation PROTO   ; 更新虛線動畫
				moveBlock PROTO             ; 遊戲主迴圈
				addTowerWithType PROTO      ; 新增指定類型的塔
				checkTowerAtCurrentPosition PROTO ; 檢查當前位置是否有塔
				deleteTower PROTO           ; 刪除塔
				isTowerAtPositionSimple PROTO ; 檢查指定索引的塔是否在當前位置
				removeTowerAtIndexSimple PROTO ; 移除指定索引的塔
				drawTower PROTO             ; 繪製單一個塔
				initMapSystem PROTO         ; 初始化地圖資料
				canPlaceTowerAtCurrentPos PROTO ; 檢查是否可建造塔
				drawMapComponents PROTO     ; 繪製所有地圖元件
				drawComponent PROTO         ; 繪製單一地圖元件
				calculateScreenPosition PROTO ; 計算螢幕座標
				drawATower PROTO            ; 繪製 Tower A (Cannon)
				drawBTower PROTO            ; 繪製 Tower B (Sniper)
				drawCTower PROTO            ; 繪製 Tower C (Ice Arrow)
				drawDTower PROTO            ; 繪製 Tower D (Mage)
				drawETower PROTO            ; 繪製 Tower E (Missile)
				drawAllTowers PROTO         ; 繪製所有已建造的塔
				restoreGraphicsAtPos PROTO  ; 重繪指定位置的圖案 (防閃爍)
				getTowerTypeAtPos PROTO     ; 取得指定位置的塔類型
				
