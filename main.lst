 00000000			.code
				; =================================================================================
				; 程式進入點 (Entry Point)
				; =================================================================================
 00000000			main PROC
				    ; 1. 取得 Console Handle
				    INVOKE GetStdHandle, STD_OUTPUT_HANDLE
 00000007  A3 00000110 R	    mov outputHandle, eax
				    INVOKE GetStdHandle, STD_INPUT_HANDLE   
 00000013  A3 00000114 R	    mov inputHandle, eax
				    
				    ; 2. 初始化視窗並最大化
 00000018  E8 00000044		    call initConsoleWindow
				
    ; 3. 設定全域背景顏色為白底黑字 (F0h) 並清屏
				    INVOKE SetConsoleTextAttribute, outputHandle, 0F0h 
 0000002D  E8 00000000 E	    call Clrscr 
				
				    ; 4. 初始化遊戲物件與地圖
 00000032  E8 00000523		    call outerBox       ; 畫邊框
 00000037  E8 00000C1D		    call initMapSystem  ; 載入地圖資料
 0000003C  E8 000005FB		    call initBlock      ; 初始化游標位置
				    
				    ; 5. 初次繪製靜態物件
 00000041  E8 00000C94		    call drawMapComponents
 00000046  E8 0000130D		    call drawAllTowers
 0000004B  E8 00000044		    call drawSideMenu
				
				    ; 6. 進入遊戲主迴圈
 00000050  E8 000003B1		    call moveBlock      
				    
 00000055  E8 00000000 E	    call Clrscr
				    exit
 00000061			main ENDP
				
				; =================================================================================
				; 設定視窗大小並最大化 (Window Initialization)
				; =================================================================================
 00000061			initConsoleWindow PROC
				    ; 強制擴大螢幕緩衝區，確保最大化時不會被切掉
				    INVOKE SetConsoleScreenBufferSize, outputHandle, newBufferSize
				
				    ; 取得視窗 Handle 並執行最大化指令
				    INVOKE GetConsoleWindow
 00000077  A3 00000004 R	    mov windowHandle, eax
				    INVOKE ShowWindow, windowHandle, SW_MAXIMIZE
				    
				    ; 稍微延遲讓視窗展開，避免繪圖錯位
 00000089  B8 00000032		    mov eax, 50
 0000008E  E8 00000000 E	    call Delay
				    
 00000093  C3			    ret
 00000094			initConsoleWindow ENDP
				
				; =================================================================================
				; 繪製常駐側邊選單 (Draw Side Menu)
				; =================================================================================
 00000094			drawSideMenu PROC USES eax ecx esi
 00000097  FF 35 00000128 R	    push DWORD PTR outerBoxPos
				    
 0000009D  B9 00000000		    mov ecx, 0
 000000A2			DRAW_MENU_LOOP:
 000000A2  83 F9 05		    cmp ecx, TOWER_MENU_COUNT
 000000A5  7D 58		    jge DRAW_MENU_FINISH
				    
				    ; 計算每個選單項目的位置: Y = START_Y + (i * SPACING)
 000000A7  8B C1		    mov eax, ecx
 000000A9  6B C0 05		    imul eax, SIDE_MENU_SPACING
 000000AC  83 C0 04		    add eax, SIDE_MENU_Y
 000000AF  66| A3		    mov outerBoxPos.Y, ax
	   0000012A R
 000000B5  66| C7 05		    mov outerBoxPos.X, SIDE_MENU_X
	   00000128 R
	   005A
				    
 000000BE  51			    push ecx
				    
				    ; 根據索引繪製對應的塔圖示
 000000BF  83 F9 00		    cmp ecx, 0
 000000C2  74 16		    je D_A
 000000C4  83 F9 01		    cmp ecx, 1
 000000C7  74 18		    je D_B
 000000C9  83 F9 02		    cmp ecx, 2
 000000CC  74 1A		    je D_C
 000000CE  83 F9 03		    cmp ecx, 3
 000000D1  74 1C		    je D_D
 000000D3  83 F9 04		    cmp ecx, 4
 000000D6  74 1E		    je D_E
 000000D8  EB 21		    jmp D_NEXT
				    
 000000DA			D_A: 
				    ; 繪製 Tower A (Cannon)
				    ; 不再預先印出名字，改由游標移動時動態顯示
 000000DA  E8 00000CD4		    call drawATower
 000000DF  EB 1A		    jmp D_NEXT
				
 000000E1			D_B: 
 000000E1  E8 00000DEE		    call drawBTower
 000000E6  EB 13		    jmp D_NEXT
				
 000000E8			D_C: 
 000000E8  E8 00000F08		    call drawCTower
 000000ED  EB 0C		    jmp D_NEXT
				
 000000EF			D_D: 
 000000EF  E8 00001022		    call drawDTower
 000000F4  EB 05		    jmp D_NEXT
				
 000000F6			D_E: 
 000000F6  E8 0000113C		    call drawETower
				
 000000FB			D_NEXT:
 000000FB  59			    pop ecx
 000000FC  41			    inc ecx
 000000FD  EB A3		    jmp DRAW_MENU_LOOP
				
 000000FF			DRAW_MENU_FINISH:
 000000FF  8F 05 00000128 R	    pop DWORD PTR outerBoxPos
				    ret
 00000109			drawSideMenu ENDP
				
				; =================================================================================
				; 繪製側邊選單游標 + 顯示對應塔名稱 (Draw Menu Cursor & Name)
				; =================================================================================
 00000109			drawSideMenuCursor PROC USES eax
 0000010A  A1 00000138 R	    mov eax, sideMenuCursorIndex
 0000010F  6B C0 05		    imul eax, SIDE_MENU_SPACING
 00000112  83 C0 04		    add eax, SIDE_MENU_Y
 00000115  83 C0 02		    add eax, 2                  ; 向下調整，對齊塔的中間
				    
 00000118  66| A3		    mov sideMenuCursorPos.Y, ax
	   0000013E R
 0000011E  66| B8 005A		    mov ax, SIDE_MENU_X
 00000122  66| 83 C0 06		    add ax, 6                   ; 畫在塔的右邊
 00000126  66| A3		    mov sideMenuCursorPos.X, ax
	   0000013C R
				    
				    ; 1. 畫游標 " << "
				    INVOKE WriteConsoleOutputAttribute, outputHandle, ADDR attrMenuCursor, 4, sideMenuCursorPos, ADDR cellsWritten
				    INVOKE WriteConsoleOutputCharacter, outputHandle, ADDR menuCursorStr, 4, sideMenuCursorPos, ADDR count
				    
				    ; 2. 游標往右移，準備畫名字
 00000166  66| 83 05		    add sideMenuCursorPos.X, 5
	   0000013C R 05
				    
				    ; 3. 根據 sideMenuCursorIndex 決定畫哪個名字
 0000016E  A1 00000138 R	    mov eax, sideMenuCursorIndex
 00000173  83 F8 00		    cmp eax, 0
 00000176  74 25		    je SHOW_NAME_A
 00000178  83 F8 01		    cmp eax, 1
 0000017B  74 5F		    je SHOW_NAME_B
 0000017D  83 F8 02		    cmp eax, 2
 00000180  0F 84 00000095	    je SHOW_NAME_C
 00000186  83 F8 03		    cmp eax, 3
 00000189  0F 84 000000C8	    je SHOW_NAME_D
 0000018F  83 F8 04		    cmp eax, 4
 00000192  0F 84 000000FB	    je SHOW_NAME_E
 00000198  E9 00000130		    jmp SKIP_NAME
				
 0000019D			SHOW_NAME_A:
				    INVOKE WriteConsoleOutputAttribute, outputHandle, ADDR attrMenuName, 7, sideMenuCursorPos, ADDR cellsWritten
				    INVOKE WriteConsoleOutputCharacter, outputHandle, ADDR strNameA, 7, sideMenuCursorPos, ADDR count
 000001D7  E9 000000F1		    jmp SKIP_NAME
 000001DC			SHOW_NAME_B:
				    INVOKE WriteConsoleOutputAttribute, outputHandle, ADDR attrMenuName, 7, sideMenuCursorPos, ADDR cellsWritten
				    INVOKE WriteConsoleOutputCharacter, outputHandle, ADDR strNameB, 7, sideMenuCursorPos, ADDR count
 00000216  E9 000000B2		    jmp SKIP_NAME
 0000021B			SHOW_NAME_C:
				    INVOKE WriteConsoleOutputAttribute, outputHandle, ADDR attrMenuName, 7, sideMenuCursorPos, ADDR cellsWritten
				    INVOKE WriteConsoleOutputCharacter, outputHandle, ADDR strNameC, 7, sideMenuCursorPos, ADDR count
 00000255  EB 76		    jmp SKIP_NAME
 00000257			SHOW_NAME_D:
				    INVOKE WriteConsoleOutputAttribute, outputHandle, ADDR attrMenuName, 7, sideMenuCursorPos, ADDR cellsWritten
				    INVOKE WriteConsoleOutputCharacter, outputHandle, ADDR strNameD, 7, sideMenuCursorPos, ADDR count
 00000291  EB 3A		    jmp SKIP_NAME
 00000293			SHOW_NAME_E:
				    INVOKE WriteConsoleOutputAttribute, outputHandle, ADDR attrMenuName, 7, sideMenuCursorPos, ADDR cellsWritten
				    INVOKE WriteConsoleOutputCharacter, outputHandle, ADDR strNameE, 7, sideMenuCursorPos, ADDR count
				
 000002CD			SKIP_NAME:
				    ret
 000002CF			drawSideMenuCursor ENDP
				
				; =================================================================================
				; 清除側邊選單游標 + 清除名稱 (Clear Menu Cursor & Name)
				; =================================================================================
 000002CF			clearSideMenuCursor PROC USES eax
 000002D0  A1 00000138 R	    mov eax, sideMenuCursorIndex
 000002D5  6B C0 05		    imul eax, SIDE_MENU_SPACING
 000002D8  83 C0 04		    add eax, SIDE_MENU_Y
 000002DB  83 C0 02		    add eax, 2                  ; 對齊塔身中間
				    
 000002DE  66| A3		    mov sideMenuCursorPos.Y, ax
	   0000013E R
 000002E4  66| B8 005A		    mov ax, SIDE_MENU_X
 000002E8  66| 83 C0 06		    add ax, 6
 000002EC  66| A3		    mov sideMenuCursorPos.X, ax
	   0000013C R
				    
				    ; 1. 清除游標 " << "
				    INVOKE WriteConsoleOutputAttribute, outputHandle, ADDR outerAttributes, 4, sideMenuCursorPos, ADDR cellsWritten
				    INVOKE WriteConsoleOutputCharacter, outputHandle, ADDR emptyLine, 4, sideMenuCursorPos, ADDR count
				    
				    ; 2. 游標往右移，準備清除名字
 0000032C  66| 83 05		    add sideMenuCursorPos.X, 5
	   0000013C R 05
				    
				    ; 3. 清除名字區域 (長度設為 10 確保清乾淨)
				    INVOKE WriteConsoleOutputAttribute, outputHandle, ADDR outerAttributes, 10, sideMenuCursorPos, ADDR cellsWritten
				    INVOKE WriteConsoleOutputCharacter, outputHandle, ADDR emptyLine, 10, sideMenuCursorPos, ADDR count
				    
				    ret
 00000370			clearSideMenuCursor ENDP
				
				; =================================================================================
				; 切換 遊戲/選單 模式 (Toggle Menu State)
				; =================================================================================
 00000370			toggleMenuState PROC
 00000370  A1 0000034E R	    mov eax, menuState
 00000375  83 F0 01		    xor eax, 1             ; 切換 0/1
 00000378  A3 0000034E R	    mov menuState, eax
				    
 0000037D  83 F8 01		    cmp eax, 1
 00000380  74 07		    je SWITCH_TO_MENU
				    
				    ; 切換回地圖模式：清除選單游標
 00000382  E8 FFFFFF48		    call clearSideMenuCursor
 00000387  EB 05		    jmp TOGGLE_DONE
				    
 00000389			SWITCH_TO_MENU:
				    ; 切換到選單模式：畫出選單游標
 00000389  E8 FFFFFD7B		    call drawSideMenuCursor
				    
 0000038E			TOGGLE_DONE:
 0000038E  C3			    ret
 0000038F			toggleMenuState ENDP
				
				; =================================================================================
				; 處理側邊選單輸入 (Handle Side Menu Input)
				; =================================================================================
 0000038F			handleSideMenuInput PROC USES eax
 00000390  66| 3D 4800		    cmp ax, 4800h ; UP Arrow
 00000394  74 0E		    je MENU_UP
 00000396  66| 3D 5000		    cmp ax, 5000h ; DOWN Arrow
 0000039A  74 28		    je MENU_DOWN
				    
 0000039C  66| 3D 1C0D		    cmp ax, 1C0Dh ; ENTER Key
 000003A0  74 49		    je MENU_SELECT
				    
 000003A2  EB 60		    jmp MENU_INPUT_DONE
				
 000003A4			MENU_UP:
 000003A4  E8 FFFFFF26		    call clearSideMenuCursor      ; 清除舊位置
 000003A9  FF 0D 00000138 R	    dec sideMenuCursorIndex
 000003AF  83 3D 00000138 R	    cmp sideMenuCursorIndex, 0
	   00
 000003B6  7D 2C		    jge UPDATE_CURSOR
 000003B8  C7 05 00000138 R	    mov sideMenuCursorIndex, 4    ; 循環到底部
	   00000004
 000003C2  EB 20		    jmp UPDATE_CURSOR
				
 000003C4			MENU_DOWN:
 000003C4  E8 FFFFFF06		    call clearSideMenuCursor      ; 清除舊位置
 000003C9  FF 05 00000138 R	    inc sideMenuCursorIndex
 000003CF  83 3D 00000138 R	    cmp sideMenuCursorIndex, 4
	   04
 000003D6  7E 0C		    jle UPDATE_CURSOR
 000003D8  C7 05 00000138 R	    mov sideMenuCursorIndex, 0    ; 循環到頂部
	   00000000
 000003E2  EB 00		    jmp UPDATE_CURSOR
				
 000003E4			UPDATE_CURSOR:
 000003E4  E8 FFFFFD20		    call drawSideMenuCursor       ; 畫新位置
 000003E9  EB 19		    jmp MENU_INPUT_DONE
				
 000003EB			MENU_SELECT:
				    ; 確認選擇：直接建造該類型的塔
 000003EB  A1 00000138 R	    mov eax, sideMenuCursorIndex
 000003F0  40			    inc eax                       ; Index(0-4) -> Type(1-5)
 000003F1  8A D8		    mov bl, al                    ; BL 傳遞給 addTowerWithType
				    
 000003F3  E8 00000610		    call addTowerWithType         ; 執行建造
 000003F8  E8 0000048D		    call restoreGraphicsAtPos     ; 立即重繪該位置以顯示結果
 000003FD  E8 FFFFFF6E		    call toggleMenuState          ; 關閉選單，切換回地圖移動模式
 00000402  EB 00		    jmp MENU_INPUT_DONE
				
 00000404			MENU_INPUT_DONE:
				    ret
 00000406			handleSideMenuInput ENDP
				
				; =================================================================================
				; 遊戲主迴圈 (Main Game Loop)
				; =================================================================================
 00000406			moveBlock PROC
 00000406			START_MOVE:
 00000406  E8 0000045E		    call updateDashAnimation    ; 更新游標閃爍動畫
				
 0000040B  83 3D 0000034E R	    cmp menuState, 1
	   01
 00000412  74 22		    je SKIP_MAP_CURSOR_UPDATE   ; 選單模式下，暫停地圖游標更新
				    
				    ; === 地圖模式繪圖 ===
 00000414  E8 00000471		    call restoreGraphicsAtPos   ; 清除上一幀的游標殘影
 00000419  E8 0000023F		    call drawMovingDashedCursor ; 畫出新的游標
				    ; 同步位置資訊
 0000041E  66| A1		    mov ax, blockPos.X
	   00000130 R
 00000424  66| A3		    mov prevBlockPos.X, ax
	   00000134 R
 0000042A  66| A1		    mov ax, blockPos.Y
	   00000132 R
 00000430  66| A3		    mov prevBlockPos.Y, ax
	   00000136 R
				    
 00000436			SKIP_MAP_CURSOR_UPDATE:
				
 00000436  B8 0000001E		    mov eax, 30                 ; 延遲 30ms
 0000043B  E8 00000000 E	    call Delay
				    
				    ; 檢查輸入緩衝區 (非阻塞)
				    INVOKE GetNumberOfConsoleInputEvents, inputHandle, ADDR numEvents
 00000450  83 3D 00000120 R	    cmp numEvents, 0
	   00
 00000457  74 29		    je NO_KEY_PRESSED   
				
 00000459  E8 00000000 E	    call ReadKey        
 0000045E  74 22		    jz NO_KEY_PRESSED
				    
				    .IF ax == 2166h ; 'f' 鍵切換選單
 00000466  E8 FFFFFF05		        call toggleMenuState
 0000046B  EB 15		        jmp NO_KEY_PRESSED
				    .ENDIF
				
				    ; 根據模式分發輸入處理
 0000046D  83 3D 0000034E R	    cmp menuState, 1
	   01
 00000474  74 07		    je CALL_MENU_INPUT
				    
 00000476  E8 00000015		    call handleNormalInput      ; 處理移動/刪除
				    
				    ; [注意] 移除了地圖模式下的 Enter 建造功能，強制透過選單建造
				    
 0000047B  EB 05		    jmp NO_KEY_PRESSED
				
 0000047D			CALL_MENU_INPUT:
 0000047D  E8 FFFFFF0D		    call handleSideMenuInput    ; 處理選單操作
				
 00000482			NO_KEY_PRESSED:
				    .IF ax == 011Bh ; ESC 鍵離開遊戲
 00000488  EB 05		        jmp EXIT_MOVE
				    .ENDIF
 0000048A  E9 FFFFFF77		    jmp START_MOVE
 0000048F			EXIT_MOVE:
 0000048F  C3			    ret
 00000490			moveBlock ENDP
				
				; =================================================================================
				; 處理一般模式輸入 (移動 + 刪除)
				; =================================================================================
 00000490			handleNormalInput PROC USES eax ebx
 00000492  66| 3D 4800		    cmp ax, 4800h ; UP
 00000496  74 21		    je HANDLE_UP
 00000498  66| 3D 5000		    cmp ax, 5000h ; DOWN
 0000049C  74 41		    je HANDLE_DOWN
 0000049E  66| 3D 4B00		    cmp ax, 4B00h ; LEFT
 000004A2  74 61		    je HANDLE_LEFT
 000004A4  66| 3D 4D00		    cmp ax, 4D00h ; RIGHT
 000004A8  74 7D		    je HANDLE_RIGHT
 000004AA  66| 3D 2D78		    cmp ax, 2d78h ; 'x' -> Delete Tower
 000004AE  0F 84 00000099	    je HANDLE_X
 000004B4  E9 0000009E		    jmp END_NORMAL_INPUT
				
 000004B9			HANDLE_UP:
 000004B9  66| 83 2D		    sub blockPos.Y, blockHeight
	   00000132 R 03
 000004C1  66| 8B 1D		    mov bx, blockPosInit.Y
	   0000012E R
 000004C8  66| 39 1D		    cmp blockPos.Y, bx
	   00000132 R
 000004CF  0F 8D 00000082	    jge END_NORMAL_INPUT
 000004D5  66| 83 05		    add blockPos.Y, blockHeight 
	   00000132 R 03
 000004DD  EB 78		    jmp END_NORMAL_INPUT
				
 000004DF			HANDLE_DOWN:
 000004DF  66| 83 05		    add blockPos.Y, blockHeight
	   00000132 R 03
 000004E7  66| BB 0015		    mov bx, (blockHeight * 7)
 000004EB  66| 03 1D		    add bx, blockPosInit.Y
	   0000012E R
 000004F2  66| 39 1D		    cmp blockPos.Y, bx
	   00000132 R
 000004F9  76 5C		    jbe END_NORMAL_INPUT
 000004FB  66| 83 2D		    sub blockPos.Y, blockHeight
	   00000132 R 03
 00000503  EB 52		    jmp END_NORMAL_INPUT
				
 00000505			HANDLE_LEFT:
 00000505  66| 83 2D		    sub blockPos.X, blockWidth
	   00000130 R 05
 0000050D  66| 8B 1D		    mov bx, blockPosInit.X
	   0000012C R
 00000514  66| 39 1D		    cmp blockPos.X, bx
	   00000130 R
 0000051B  73 3A		    jae END_NORMAL_INPUT
 0000051D  66| 83 05		    add blockPos.X, blockWidth
	   00000130 R 05
 00000525  EB 30		    jmp END_NORMAL_INPUT
				
 00000527			HANDLE_RIGHT:
 00000527  66| 83 05		    add blockPos.X, blockWidth
	   00000130 R 05
 0000052F  66| BB 004B		    mov bx, (blockWidth * 15)
 00000533  66| 03 1D		    add bx, blockPosInit.X
	   0000012C R
 0000053A  66| 39 1D		    cmp blockPos.X, bx
	   00000130 R
 00000541  76 14		    jbe END_NORMAL_INPUT
 00000543  66| 83 2D		    sub blockPos.X, blockWidth
	   00000130 R 05
 0000054B  EB 0A		    jmp END_NORMAL_INPUT
				    
 0000054D			HANDLE_X:
 0000054D  E8 0000056B		    call deleteTower 
 00000552  E8 00000333		    call restoreGraphicsAtPos
				    
 00000557			END_NORMAL_INPUT:
				    ret
 0000055A			handleNormalInput ENDP
				
				; =================================================================================
				; 繪圖函式 (使用 F0h 白底屬性)
				; =================================================================================
				
				; 繪製遊戲外框
 0000055A			outerBox PROC USES eax ecx
 0000055C  66| A1		    mov ax, outerBoxPosInit.X
